#!/bin/sh
#
# Gradle wrapper script — bootstraps Gradle using the version in
# gradle/wrapper/gradle-wrapper.properties.
# Requires gradle-wrapper.jar — run `gradle wrapper` once if missing.
#

set -e
APP_HOME="$(cd "$(dirname "$0")" && pwd)"
GRADLE_OPTS="${GRADLE_OPTS} -Dfile.encoding=UTF-8"

exec "${APP_HOME}/gradle/wrapper/gradle-wrapper" "$@" 2>/dev/null \
  || exec gradle "$@"
